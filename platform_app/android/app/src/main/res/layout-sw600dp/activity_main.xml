<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FB"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:paddingBottom="18dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#12212F"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/service_shell_subtitle"
            android:textColor="#5E6A75"
            android:textSize="15sp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:id="@+id/contentInner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/leftColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:layout_weight="0.9"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/statusPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_background"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/serviceControlTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/service_control_title"
                        android:textColor="#12212F"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/statusLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/status"
                        android:textColor="#607080"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/service_stopped"
                        android:textColor="#12212F"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/messageText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/service_ready_hint"
                        android:textColor="#465461"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/startStopButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/start_service" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/copyLanButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="@string/copy_lan_url" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/openLocalButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:text="@string/open_local" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/networkPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/networkTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/network_title"
                        android:textColor="#12212F"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/networkHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/network_hint"
                        android:textColor="#5E6A75"
                        android:textSize="13sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/portInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/port">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/portEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/localUrlLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/local_url"
                        android:textColor="#607080"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/localUrlText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="monospace"
                        android:text="@string/url_placeholder"
                        android:textColor="#12212F"
                        android:textIsSelectable="true"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/lanUrlLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/lan_url"
                        android:textColor="#607080"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/lanUrlText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="monospace"
                        android:text="@string/url_placeholder"
                        android:textColor="#12212F"
                        android:textIsSelectable="true"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/savePortButton"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/save_port" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rightColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.1"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/foldersPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/panel_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/foldersTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/folders_title"
                        android:textColor="#12212F"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/foldersHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/folders_hint"
                        android:textColor="#5E6A75"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/foldersText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="monospace"
                        android:text="@string/no_folders"
                        android:textColor="#12212F"
                        android:textIsSelectable="true"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/foldersSaveHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/save_restart_hint"
                        android:textColor="#7A5361"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:id="@+id/folderButtonsTop"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addSystemAlbumsButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:text="@string/add_system_albums" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/addAppAlbumButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="8dp"
                            android:text="@string/add_app_album" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/scanExternalStorageButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="8dp"
                            android:text="@string/scan_external_storage" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/removeFoldersButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="8dp"
                            android:text="@string/remove_folders" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/logsPanel"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:background="@drawable/panel_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:id="@+id/logActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/logsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/logs_title"
                            android:textColor="#12212F"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/refreshLogsButton"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/refresh_logs" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clearLogsButton"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/clear_logs" />
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/logScroll"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="8dp"
                        android:layout_weight="1"
                        android:fillViewport="true">

                        <TextView
                            android:id="@+id/logText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="@string/logs_placeholder"
                            android:textColor="#465461"
                            android:textIsSelectable="true"
                            android:textSize="12sp" />
                    </ScrollView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/copyLogsButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:text="@string/copy_logs" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
